{
  "expo": {
    "name": "Ada",
    "slug": "ada",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ada",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.ada.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Ada uses your microphone for the voice intake — she interviews you briefly and drafts your run."
      }
    },
    "android": {
      "package": "app.ada.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#17150f",
        "foregroundImage": "./assets/images/splash-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf9f6",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 110,
          "dark": {
            "backgroundColor": "#12110e"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
