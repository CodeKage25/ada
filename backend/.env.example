APP_ENV=local
LOG_LEVEL=INFO
# Comma-separated allowlist in staging/prod (wildcard is rejected there).
ALLOWED_ORIGIN=*

# database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ada
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

# gcp / vertex (Gemini)
GCP_PROJECT=your-project
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
LIVE_MODEL=gemini-2.0-flash-live-preview-04-09
LLM_TIMEOUT_MS=60000
LLM_MAX_ATTEMPTS=3

# matching + interview
JOBS_MATCH_K=5
INTERVIEW_QUESTIONS=5
STUCK_RUN_SECONDS=300

# auth (magic links) — local logs the link instead of emailing
FRONTEND_ORIGIN=http://localhost:3000
RESEND_API_KEY=
EMAIL_FROM=Ada <auth@yourdomain.com>

# paystack — NGN (secrets go to Secret Manager in prod, not here)
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx
PRICE_KOBO=200000        # NGN 2,000
CURRENCY=NGN

# stripe — global (secrets go to Secret Manager in prod)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_USD_CENTS=1500
STRIPE_CURRENCY=usd
